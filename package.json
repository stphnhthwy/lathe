{
  "name": "@lathe/cli",
  "version": "0.1.0",
  "description": "Turn a small YAML manifest into a working MCP server + Agent Skill. The manifest never executes — lathe reads the declaration and runs real code.",
  "license": "MIT",
  "author": "Stephen Hathaway",
  "homepage": "https://github.com/stphnhthwy/lathe#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stphnhthwy/lathe.git"
  },
  "bugs": {
    "url": "https://github.com/stphnhthwy/lathe/issues"
  },
  "type": "module",
  "bin": {
    "lathe": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "check": "tsx src/cli.ts check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent-skills",
    "claude",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
